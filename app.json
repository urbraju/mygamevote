{
  "expo": {
    "_comment": "Expo Configuration. Defines app metadata (name, slug, version), orientation, icon, splash screen, and ios/android specific settings.",
    "name": "MyGameVote",
    "slug": "MyGameVote",
    "version": "1.0.0",
    "scheme": "mygamevote",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.masti.mygamevote",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.masti.mygamevote",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "owner": "brutechgyan",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/722571257298"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ea6a4e1c-5f60-44d9-baad-6f11496a35c9"
      }
    }
  }
}