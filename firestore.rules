rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true) ||
        request.auth.token.email in ['urbraju@gmail.com', 'brutechgyan@gmail.com']
      );
    }

    // Multi-tenancy helpers
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOf(orgId) {
      return isAuthenticated() && (
        isAdmin() || // Global admin can see everything
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         orgId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('orgIds', []))
      );
    }

    function isOrgAdmin(orgId) {
      return isAuthenticated() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/organizations/$(orgId)) &&
         request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.get('admins', []))
      );
    }


    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() || request.query.limit <= 1;
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isApproved', 'orgIds', 'activeOrgId'])
        ) ||  
        isAdmin() ||
        // Allow Org Admins to manage users in their org (approval, roles, skills, etc)
        (
          'activeOrgId' in getProfile() && 
          isOrgAdmin(getProfile().activeOrgId) &&
          (
            // If they are approving into THEIR org
            (request.resource.data.diff(resource.data).affectedKeys().hasAny(['isApproved', 'orgIds', 'activeOrgId', 'sportsInterests', 'skills']) &&
             getProfile().activeOrgId in request.resource.data.get('orgIds', [])) ||
            // Or general profile management for THEIR members
            (resource.data.get('activeOrgId', '') == getProfile().activeOrgId)
          )
        ) ||
        // Legacy: Allow Org Admins to approve users (sync profile fields)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isApproved', 'orgIds', 'activeOrgId', 'sportsInterests']) &&
         // Check if they are an admin of at least one org or have admin-ish status
         (getProfile().get('isAdmin', false) == true ||
          isOrgAdmin('default') ||
          isOrgAdmin(getProfile().get('activeOrgId', 'default')))
        )
      );
      allow delete: if isAdmin() || (
        'activeOrgId' in getProfile() && 
        isOrgAdmin(getProfile().activeOrgId) &&
        resource.data.get('activeOrgId', '') == getProfile().activeOrgId
      );
    }

    // Global Settings collection - PUBLIC READ
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || isOrgAdmin('default');
    }

    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOrgAdmin(orgId) || 
        // Allow a user to add THEMSELVES to members (if joining an org that doesn't require approval)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) && 
         request.resource.data.members.hasAll(resource.data.get('members', [])) &&
         request.resource.data.members.size() == resource.data.get('members', []).size() + 1 &&
         request.auth.uid in request.resource.data.members) ||
        // Allow a user to add THEMSELVES to pendingMembers
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingMembers']) && 
         request.resource.data.pendingMembers.hasAll(resource.data.get('pendingMembers', [])) &&
         request.resource.data.pendingMembers.size() == resource.data.get('pendingMembers', []).size() + 1 &&
         request.auth.uid in request.resource.data.pendingMembers)
      );
      allow delete: if isOrgAdmin(orgId);

      // Organization-specific settings
      match /settings/{settingId} {
        allow read: if isAuthenticated() && (isMemberOf(orgId));
        allow write: if isOrgAdmin(orgId);
      }
    }

    // Weekly Slots collection (Legacy)
    match /weekly_slots/{weekId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        !('orgId' in resource.data) || 
        isMemberOf(resource.data.get('orgId', 'default')) ||
        isOrgAdmin(resource.data.get('orgId', 'default'))
      );
      allow create: if isAdmin() || (
        'orgId' in request.resource.data && isOrgAdmin(request.resource.data.orgId)
      );
      allow delete: if isAdmin() || (
        'orgId' in resource.data && isOrgAdmin(resource.data.orgId)
      );
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.get('orgId', 'default') != null && isOrgAdmin(resource.data.get('orgId', 'default'))) ||
        (isMemberOf(resource.data.get('orgId', 'default')) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['slots']))
      );
      
      match /payments/{paymentId} {
        allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isOrgAdmin(get(/databases/$(database)/documents/weekly_slots/$(weekId)).data.orgId));
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
        allow update: if isAdmin() || isOrgAdmin(get(/databases/$(database)/documents/weekly_slots/$(weekId)).data.orgId);
      }
    }

    // Events collection (Phase 2 Multi-Sport)
    match /events/{eventId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        !('orgId' in resource.data) || 
        isMemberOf(resource.data.get('orgId', 'default')) ||
        isOrgAdmin(resource.data.get('orgId', 'default'))
      );
      allow create: if isAdmin() || (
        'orgId' in request.resource.data && isOrgAdmin(request.resource.data.orgId)
      );
      allow delete: if isAdmin() || (
        'orgId' in resource.data && isOrgAdmin(resource.data.orgId)
      );
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.get('orgId', 'default') != null && isOrgAdmin(resource.data.get('orgId', 'default'))) ||
        (isMemberOf(resource.data.get('orgId', 'default')) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['slots', 'participantIds'])) ||
        (request.auth.uid in resource.data.get('participantIds', []) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['liveScore'])) ||
        (isOrgAdmin(resource.data.get('orgId', 'default')) && request.resource.data.diff(resource.data).affectedKeys().hasAny(['isTeamSplittingEnabled', 'teams']))
      );
    }


    // Public collection (specifically for time sync)
    match /public/time_sync {
      // Allow public read/write for time synchronization before login
      allow read, write: if true;
    }

    match /public/{docId} {
      // Other public docs still require authentication
      allow read, write: if isAuthenticated();
    }

    // Interest Requests collection
    match /interestRequests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isOrgAdmin(resource.data.orgId));
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isOrgAdmin(resource.data.orgId);
    }

    // Sports collection
    match /sports/{sportId} {
      allow read: if true; // Publicly readable for signup displays
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (request.resource.data.get('orgId', 'default') != 'system' && 
         isOrgAdmin(request.resource.data.get('orgId', 'default')))
      );
      allow update, delete: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.get('orgId', 'default') != 'system' && 
         isOrgAdmin(resource.data.get('orgId', 'default')))
      );
    }
  }
}
